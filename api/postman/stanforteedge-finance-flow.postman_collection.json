{
  "info": {
    "name": "StanforteEdge Finance Request Flow",
    "description": "End-to-end finance request lifecycle for StanforteEdge API v1.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Auth - Staff Login",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{staff_email}}\",\n  \"password\": \"{{staff_password}}\"\n}"
        },
        "url": "{{base_url}}/v1/auth/login"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const body = pm.response.json();",
              "const payload = body.data || body;",
              "const token = payload.access_token || payload.token || payload.accessToken;",
              "if (token) pm.environment.set('staff_token', token);"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "2. Auth - Approver Login",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{approver_email}}\",\n  \"password\": \"{{approver_password}}\"\n}"
        },
        "url": "{{base_url}}/v1/auth/login"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const body = pm.response.json();",
              "const payload = body.data || body;",
              "const token = payload.access_token || payload.token || payload.accessToken;",
              "if (token) pm.environment.set('approver_token', token);"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "3. Auth - Finance Login",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{finance_email}}\",\n  \"password\": \"{{finance_password}}\"\n}"
        },
        "url": "{{base_url}}/v1/auth/login"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const body = pm.response.json();",
              "const payload = body.data || body;",
              "const token = payload.access_token || payload.token || payload.accessToken;",
              "if (token) pm.environment.set('finance_token', token);"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "4. Requests - List Types",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{staff_token}}" }
        ],
        "url": "{{base_url}}/v1/requests/types"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const body = pm.response.json();",
              "const rows = body.data || body || [];",
              "if (Array.isArray(rows)) {",
              "  const petty = rows.find((x) => x.codePrefix === 'PC' || x.code_prefix === 'PC');",
              "  const op = rows.find((x) => x.codePrefix === 'OP' || x.code_prefix === 'OP');",
              "  if (petty?.id) pm.environment.set('pc_request_type_id', petty.id);",
              "  if (op?.id) pm.environment.set('op_request_type_id', op.id);",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "5. Files - Create Asset",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{staff_token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"storage_disk\": \"local\",\n  \"storage_path\": \"uploads/requests/invoice-001.pdf\",\n  \"file_name\": \"invoice-001.pdf\",\n  \"mime_type\": \"application/pdf\",\n  \"file_size\": 200123,\n  \"file_url\": \"https://cdn.example.com/uploads/requests/invoice-001.pdf\"\n}"
        },
        "url": "{{base_url}}/v1/files"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const body = pm.response.json();",
              "const row = body.data || body;",
              "if (row?.id) pm.environment.set('request_item_file_id', row.id);"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "6. Requests - Create Draft",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{staff_token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"request_type_id\": \"{{pc_request_type_id}}\",\n  \"data\": {\n    \"purpose\": \"Petty cash for field operations\",\n    \"project\": \"HQ Revamp\",\n    \"reimbursement\": false\n  },\n  \"currency\": \"NGN\",\n  \"items\": [\n    {\n      \"description\": \"Diesel purchase\",\n      \"amount\": 25000,\n      \"quantity\": 1,\n      \"notes\": \"Generator support\",\n      \"file_id\": \"{{request_item_file_id}}\"\n    }\n  ]\n}"
        },
        "url": "{{base_url}}/v1/requests"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const body = pm.response.json();",
              "const row = body.data || body;",
              "if (row?.id) pm.environment.set('request_id', row.id);"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "7. Requests - Submit",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{staff_token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"comment\": \"Please review urgently\"\n}"
        },
        "url": "{{base_url}}/v1/requests/{{request_id}}/submit"
      }
    },
    {
      "name": "8. Requests - Approve (Approver)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{approver_token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"action\": \"approve\",\n  \"comment\": \"Approved\"\n}"
        },
        "url": "{{base_url}}/v1/requests/{{request_id}}/approve"
      }
    },
    {
      "name": "9. Requests - Approve (Finance/Final)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{finance_token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"action\": \"approve\",\n  \"comment\": \"Cleared for disbursement\"\n}"
        },
        "url": "{{base_url}}/v1/requests/{{request_id}}/approve"
      }
    },
    {
      "name": "10. Finance - Disburse",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{finance_token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"note\": \"Transferred. Ref: STN240217001\"\n}"
        },
        "url": "{{base_url}}/v1/finance/requests/{{request_id}}/disburse"
      }
    },
    {
      "name": "11. Requests - Confirm Disbursement",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{staff_token}}" }
        ],
        "url": "{{base_url}}/v1/requests/{{request_id}}/confirm"
      }
    },
    {
      "name": "12. Requests - Retire",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{staff_token}}" }
        ],
        "url": "{{base_url}}/v1/requests/{{request_id}}/retire"
      }
    },
    {
      "name": "13. Requests - Complete",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{finance_token}}" }
        ],
        "url": "{{base_url}}/v1/requests/{{request_id}}/complete"
      }
    },
    {
      "name": "14. Requests - Generate PDF",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{staff_token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"id\": \"{{request_id}}\"\n}"
        },
        "url": "{{base_url}}/v1/requests/generate-pdf"
      }
    },
    {
      "name": "15. Requests - Generate Voucher",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{finance_token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"id\": \"{{request_id}}\"\n}"
        },
        "url": "{{base_url}}/v1/requests/generate-pv"
      }
    }
  ]
}
