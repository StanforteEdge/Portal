datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum TokenType {
  access
  refresh
  reset
  invite
}

enum OrganizationType {
  group
  venture
  shared_function
}

enum GroupUserRole {
  member
  admin
  moderator
}

enum RequestStatus {
  draft
  sent
  approval
  cleared
  approved
  rejected
  cancelled
  payment_processing
  disbursed
  confirmed
  partially_disbursed
  pending_retirement
  retired
  completed
}

enum EmploymentType {
  full_time
  contract
  intern
  consultant
}

enum EmploymentStatus {
  draft
  active
  suspended
  exited
}

enum WorkMode {
  onsite
  hybrid
  remote
}

enum OnboardingStatus {
  invited
  accepted
  profile_pending
  forms_pending
  hr_review
  completed
}

model Profile {
  id                     BigInt   @id @default(autoincrement())
  wpUserId               BigInt?   @map("wp_user_id")
  username               String    @unique @db.VarChar(100)
  email                  String    @unique @db.VarChar(255)
  passwordHash           String?   @map("password_hash") @db.VarChar(255)
  type                   String    @db.VarChar(50)
  status                 String    @default("active") @db.VarChar(20)
  firstName              String?   @map("first_name") @db.VarChar(100)
  lastName               String?   @map("last_name") @db.VarChar(100)
  dateOfBirth            DateTime? @map("date_of_birth") @db.Date
  gender                 String?   @db.VarChar(10)
  phone                  String?   @db.VarChar(30)
  address                String?   @db.VarChar(255)
  nationality            String?   @db.VarChar(100)
  state                  String?   @db.VarChar(100)
  lga                    String?   @db.VarChar(100)
  maritalStatus          String?   @map("marital_status") @db.VarChar(30)
  avatar                 String?   @db.VarChar(255)
  bio                    String?
  occupation             String?   @db.VarChar(100)
  employmentType         String?   @map("employment_type") @db.VarChar(20)
  primaryOrganizationId  BigInt?   @map("primary_organization_id")
  lastLogin              DateTime? @map("last_login") @db.Timestamp(6)
  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime  @updatedAt @map("updated_at")

  primaryOrganization Organization? @relation("PrimaryOrganization", fields: [primaryOrganizationId], references: [id])

  organizations ProfileOrganization[]
  roles         UserRole[]
  tokens        Token[]
  groups        GroupUser[]
  requests      RequestInstance[] @relation("RequestCreatedBy")
  uploadedFiles FileAsset[] @relation("FileUploadedBy")
  emailLogs     EmailLog[] @relation("EmailLogUser")
  employeeProfile EmployeeProfile?
  managedEmployees EmployeeProfile[] @relation("EmployeeManager")
  onboardingProgress OnboardingProgress?
  employeeMeta EmployeeMeta[]
  acknowledgements Acknowledgement[]
  documentAcknowledgements DocumentAcknowledgement[]

  @@map("sta_profiles")
}

model EmployeeProfile {
  id                    String           @id @default(uuid()) @db.Uuid
  userId                BigInt           @unique @map("user_id")
  employeeCode          String?          @unique @map("employee_code") @db.VarChar(60)
  jobTitle              String?          @map("job_title") @db.VarChar(120)
  jobDescription        String?          @map("job_description")
  managerUserId         BigInt?          @map("manager_user_id")
  employmentType        EmploymentType?  @map("employment_type")
  employmentStatus      EmploymentStatus @default(draft) @map("employment_status")
  hireDate              DateTime?        @map("hire_date") @db.Date
  confirmationDate      DateTime?        @map("confirmation_date") @db.Date
  exitDate              DateTime?        @map("exit_date") @db.Date
  workMode              WorkMode?        @map("work_mode")
  primaryTeamId         BigInt?          @map("primary_team_id")
  primaryOrganizationId BigInt?          @map("primary_organization_id")
  createdBy             BigInt?          @map("created_by")
  updatedBy             BigInt?          @map("updated_by")
  createdAt             DateTime         @default(now()) @map("created_at")
  updatedAt             DateTime         @updatedAt @map("updated_at")

  user                Profile       @relation(fields: [userId], references: [id], onDelete: Cascade)
  manager             Profile?      @relation("EmployeeManager", fields: [managerUserId], references: [id], onDelete: SetNull)
  primaryTeam         Group?        @relation(fields: [primaryTeamId], references: [id], onDelete: SetNull)
  primaryOrganization Organization? @relation(fields: [primaryOrganizationId], references: [id], onDelete: SetNull)

  @@index([managerUserId])
  @@index([primaryTeamId])
  @@index([primaryOrganizationId])
  @@index([employmentStatus])
  @@map("sta_employee_profiles")
}

model EmployeeMeta {
  id        String   @id @default(uuid()) @db.Uuid
  userId    BigInt   @map("user_id")
  metaKey   String   @map("meta_key") @db.VarChar(120)
  metaValue Json?    @map("meta_value")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user     Profile         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, metaKey], name: "employee_meta_unique")
  @@index([metaKey])
  @@map("sta_employee_meta")
}

model OnboardingProgress {
  id          String           @id @default(uuid()) @db.Uuid
  userId      BigInt           @unique @map("user_id")
  status      OnboardingStatus @default(invited)
  currentStep String?          @map("current_step") @db.VarChar(80)
  stepsJson   Json?            @map("steps_json")
  dueDate     DateTime?        @map("due_date") @db.Date
  completedAt DateTime?        @map("completed_at")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  user Profile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
  @@map("sta_onboarding_progress")
}

model Organization {
  id                   BigInt            @id @default(autoincrement())
  name                 String            @db.VarChar(255)
  code                 String            @unique @db.VarChar(50)
  parentOrganizationId BigInt?           @map("parent_organization_id")
  organizationType     OrganizationType  @default(venture) @map("organization_type")
  isActive             Boolean           @default(true) @map("is_active")
  metadata             Json?
  createdAt            DateTime          @map("created_at")
  updatedAt            DateTime          @map("updated_at")

  parentOrganization Organization? @relation("OrgParent", fields: [parentOrganizationId], references: [id])
  childOrganizations Organization[] @relation("OrgParent")
  primaryProfiles   Profile[] @relation("PrimaryOrganization")

  profiles ProfileOrganization[]
  userRoles UserRole[]
  groups    Group[]
  requests  RequestInstance[]
  requestGroups RequestGroup[]
  fileAssets FileAsset[]
  employeeProfiles EmployeeProfile[]
  documents Document[]

  @@map("sta_organizations")
}

model ProfileOrganization {
  id              String   @id @default(uuid()) @db.Uuid
  profileId       BigInt   @map("profile_id")
  organizationId  BigInt   @map("organization_id")
  isPrimary       Boolean  @default(false) @map("is_primary")
  startDate       DateTime? @map("start_date") @db.Date
  endDate         DateTime? @map("end_date") @db.Date
  createdAt       DateTime  @map("created_at")

  profile       Profile      @relation(fields: [profileId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([profileId, organizationId], name: "profile_org_unique")
  @@map("sta_profile_organizations")
}

model Role {
  id          BigInt   @id @default(autoincrement())
  name        String   @db.VarChar(50)
  description String?
  slug        String   @unique @db.VarChar(50)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @map("created_at")
  updatedAt   DateTime @map("updated_at")

  permissions RolePermission[]
  users       UserRole[]

  @@map("sta_roles")
}

model Permission {
  id          BigInt   @id @default(autoincrement())
  name        String   @db.VarChar(50)
  description String?
  slug        String   @unique @db.VarChar(50)
  module      String?  @db.VarChar(50)
  createdAt   DateTime @map("created_at")
  updatedAt   DateTime @map("updated_at")

  roles RolePermission[]

  @@map("sta_permissions")
}

model RolePermission {
  roleId       BigInt   @map("role_id")
  permissionId BigInt   @map("permission_id")
  assignedAt   DateTime @default(now()) @map("assigned_at")

  role       Role       @relation(fields: [roleId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])

  @@id([roleId, permissionId])
  @@map("sta_role_permissions")
}

model UserRole {
  id             BigInt   @id @default(autoincrement())
  profileId      BigInt   @map("profile_id")
  roleId         BigInt   @map("role_id")
  organizationId BigInt?  @map("organization_id")
  isPrimaryRole  Boolean  @default(false) @map("is_primary_role")
  assignedAt     DateTime @default(now()) @map("assigned_at")
  createdAt      DateTime @default(now()) @map("created_at")

  profile      Profile      @relation(fields: [profileId], references: [id])
  role         Role         @relation(fields: [roleId], references: [id])
  organization Organization? @relation(fields: [organizationId], references: [id])

  @@unique([profileId, roleId, organizationId], name: "profile_role_org_unique")
  @@map("sta_user_roles")
}

model Token {
  id        String    @id @db.VarChar(255)
  profileId BigInt    @map("profile_id")
  type      TokenType
  tokenHash String    @map("token_hash") @db.VarChar(255)
  expiresAt DateTime  @map("expires_at")
  lastUsedAt DateTime? @map("last_used_at")
  userAgent String?
  ipAddress String?   @map("ip_address") @db.VarChar(45)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  profile Profile @relation(fields: [profileId], references: [id])

  @@index([profileId])
  @@index([tokenHash])
  @@index([type])
  @@index([expiresAt])
  @@unique([tokenHash, type], name: "unique_token_hash_type")
  @@map("sta_tokens")
}

model Notification {
  id             BigInt    @id @default(autoincrement())
  userId         BigInt    @map("user_id")
  type           String    @default("info") @db.VarChar(50)
  title          String    @db.VarChar(255)
  message        String
  link           String?   @db.VarChar(255)
  data           Json?
  status         String    @default("unread") @db.VarChar(20)
  readAt         DateTime? @map("read_at")
  archivedAt     DateTime? @map("archived_at")
  sentVia        Json?     @map("sent_via")
  notifiableType String?   @map("notifiable_type") @db.VarChar(100)
  notifiableId   BigInt?   @map("notifiable_id")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@index([userId])
  @@index([type])
  @@index([status])
  @@index([notifiableType, notifiableId])
  @@map("sta_notifications")
}

model EmailLog {
  id             BigInt    @id @default(autoincrement())
  userId         BigInt?   @map("user_id")
  toEmail        String    @map("to_email") @db.VarChar(255)
  subject        String    @db.VarChar(255)
  bodyText       String?   @map("body_text")
  bodyHtml       String?   @map("body_html")
  threadKey      String?   @map("thread_key") @db.VarChar(191)
  provider       String?   @db.VarChar(50)
  status         String    @default("queued") @db.VarChar(20)
  messageId      String?   @map("message_id") @db.VarChar(255)
  errorMessage   String?   @map("error_message")
  notifiableType String?   @map("notifiable_type") @db.VarChar(100)
  notifiableId   BigInt?   @map("notifiable_id")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  user Profile? @relation("EmailLogUser", fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([notifiableType, notifiableId])
  @@map("sta_email_logs")
}

model Group {
  id          BigInt   @id @default(autoincrement())
  name        String   @db.VarChar(255)
  description String?
  type        String   @default("general") @db.VarChar(50)
  parentId    BigInt?  @map("parent_id")
  metadata    Json?
  isActive    Boolean  @default(true) @map("is_active")
  createdBy   BigInt?  @map("created_by")
  updatedBy   BigInt?  @map("updated_by")
  organizationId BigInt? @map("organization_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  parent Group? @relation("GroupParent", fields: [parentId], references: [id])
  children Group[] @relation("GroupParent")

  organization Organization? @relation(fields: [organizationId], references: [id])

  members GroupUser[]
  employeeProfiles EmployeeProfile[]

  @@map("sta_groups")
}

model GroupUser {
  id       BigInt        @id @default(autoincrement())
  groupId  BigInt        @map("group_id")
  userId   BigInt        @map("user_id")
  role     GroupUserRole @default(member)
  joinedAt DateTime      @default(now()) @map("joined_at")
  addedBy  BigInt?       @map("added_by")

  group   Group   @relation(fields: [groupId], references: [id])
  user    Profile @relation(fields: [userId], references: [id])

  @@unique([groupId, userId], name: "unique_group_user")
  @@map("sta_group_users")
}

model RequestGroup {
  id          String   @id @default(uuid()) @db.Uuid
  organizationId BigInt? @map("organization_id")
  name        String   @db.VarChar(100)
  code        String   @unique @db.VarChar(20)
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  organization Organization? @relation(fields: [organizationId], references: [id])
  requestTypes RequestType[]
  requests     RequestInstance[]

  @@map("sta_request_groups")
}

model RequestType {
  id               String   @id @default(uuid()) @db.Uuid
  groupId          String   @map("group_id") @db.Uuid
  name             String   @db.VarChar(100)
  codePrefix       String   @map("code_prefix") @db.VarChar(10)
  categoryKey      String?  @map("category_key") @db.VarChar(100)
  description      String?
  storageType      String?  @map("storage_type") @db.VarChar(20)
  formSchema       Json?    @map("form_schema")
  approvalFlowJson Json?    @map("approval_flow_json")
  approvalLimit    Decimal? @map("approval_limit") @db.Decimal(15,2)
  sequenceCounter  Int      @default(0) @map("sequence_counter")
  isActive         Boolean  @default(true) @map("is_active")
  formId           String?  @map("form_id") @db.Uuid
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  group RequestGroup @relation(fields: [groupId], references: [id])
  requests RequestInstance[]

  @@unique([groupId, codePrefix], name: "unique_group_code_prefix")
  @@map("sta_request_types")
}

model RequestInstance {
  id                BigInt   @id @default(autoincrement())
  requestTypeId     String   @map("request_type_id") @db.Uuid
  groupId           String   @map("group_id") @db.Uuid
  organizationId    BigInt?  @map("organization_id")
  createdBy         BigInt   @map("created_by")
  teamId            BigInt?  @map("team_id")
  workflowInstanceId String? @map("workflow_instance_id") @db.Uuid
  status            RequestStatus @default(draft)
  data              Json?
  currentApprovalStep Int    @default(0) @map("current_approval_step")
  auditLogId        String?  @map("audit_log_id") @db.Uuid
  totalAmount       Decimal? @map("total_amount") @db.Decimal(15,2)
  currency          String   @default("NGN") @db.VarChar(3)
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  requestType RequestType @relation(fields: [requestTypeId], references: [id])
  group       RequestGroup @relation(fields: [groupId], references: [id])
  organization Organization? @relation(fields: [organizationId], references: [id])
  creator     Profile @relation("RequestCreatedBy", fields: [createdBy], references: [id])
  items       RequestItem[]
  paymentVouchers FinancePaymentVoucher[]

  @@index([requestTypeId])
  @@index([groupId])
  @@index([createdBy])
  @@index([teamId])
  @@index([status])
  @@index([workflowInstanceId])
  @@map("sta_request_instances")
}

model RequestItem {
  id            String   @id @default(uuid()) @db.Uuid
  requestId     BigInt   @map("request_id")
  fileId        String?  @map("file_id") @db.Uuid
  categoryId    String?  @map("category_id") @db.Uuid
  subcategoryId String?  @map("subcategory_id") @db.Uuid
  description   String
  amount        Decimal  @db.Decimal(15,2)
  quantity      Int      @default(1)
  dueDate       DateTime? @map("due_date") @db.Date
  notes         String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  request RequestInstance @relation(fields: [requestId], references: [id], onDelete: Cascade)
  file    FileAsset?      @relation(fields: [fileId], references: [id], onDelete: SetNull)

  @@index([requestId])
  @@index([fileId])
  @@index([categoryId])
  @@index([subcategoryId])
  @@map("sta_request_items")
}

model FinanceSetting {
  id        String   @id @default(uuid()) @db.Uuid
  key       String   @unique @db.VarChar(100)
  config    Json?
  updatedBy BigInt?  @map("updated_by")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("sta_finance_settings")
}

model FileAsset {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId BigInt?  @map("organization_id")
  uploadedBy     BigInt?  @map("uploaded_by")
  storageDisk    String   @default("local") @map("storage_disk") @db.VarChar(30)
  storagePath    String   @map("storage_path") @db.VarChar(500)
  fileName       String   @map("file_name") @db.VarChar(255)
  mimeType       String?  @map("mime_type") @db.VarChar(120)
  fileSize       BigInt?  @map("file_size")
  publicUrl      String?  @map("public_url") @db.VarChar(500)
  metadata       Json?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization? @relation(fields: [organizationId], references: [id])
  uploader     Profile?      @relation("FileUploadedBy", fields: [uploadedBy], references: [id])
  requestItems RequestItem[]
  financePaymentVouchers FinancePaymentVoucher[]
  documents Document[]

  @@index([organizationId])
  @@index([uploadedBy])
  @@map("sta_file_assets")
}

model Document {
  id                     String    @id @default(uuid()) @db.Uuid
  organizationId         BigInt?   @map("organization_id")
  title                  String    @db.VarChar(255)
  slug                   String    @unique @db.VarChar(180)
  category               String    @default("policy") @db.VarChar(50)
  status                 String    @default("draft") @db.VarChar(30)
  version                String    @default("1.0") @db.VarChar(40)
  effectiveDate          DateTime? @map("effective_date") @db.Date
  contentHtml            String?   @map("content_html")
  fileId                 String?   @map("file_id") @db.Uuid
  requireAcknowledgement Boolean   @default(false) @map("require_acknowledgement")
  createdBy              BigInt?   @map("created_by")
  updatedBy              BigInt?   @map("updated_by")
  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime  @updatedAt @map("updated_at")

  organization      Organization?            @relation(fields: [organizationId], references: [id])
  file              FileAsset?               @relation(fields: [fileId], references: [id], onDelete: SetNull)
  acknowledgements  DocumentAcknowledgement[]

  @@index([organizationId])
  @@index([status])
  @@index([category])
  @@map("sta_documents")
}

model DocumentAcknowledgement {
  id             String   @id @default(uuid()) @db.Uuid
  documentId     String   @map("document_id") @db.Uuid
  userId         BigInt   @map("user_id")
  version        String   @db.VarChar(40)
  acknowledgedAt DateTime @default(now()) @map("acknowledged_at")
  ipAddress      String?  @map("ip_address") @db.VarChar(64)
  userAgent      String?  @map("user_agent") @db.VarChar(512)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  user     Profile  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([documentId, userId, version], name: "unique_document_ack")
  @@index([userId])
  @@map("sta_document_acknowledgements")
}

model FinancePaymentVoucher {
  id               String   @id @default(uuid()) @db.Uuid
  requestId        BigInt   @map("request_id")
  voucherNumber    String   @map("voucher_number") @db.VarChar(60)
  amount           Decimal  @db.Decimal(15,2)
  retiredAmount    Decimal  @default(0) @map("retired_amount") @db.Decimal(15,2)
  retirementStatus String   @default("not_retired") @map("retirement_status") @db.VarChar(20)
  method           String?  @db.VarChar(40)
  transactionRef   String?  @map("transaction_ref") @db.VarChar(120)
  note             String?
  evidenceFileId   String?  @map("evidence_file_id") @db.Uuid
  disbursedAt      DateTime @map("disbursed_at")
  retiredAt        DateTime? @map("retired_at")
  verifiedAt       DateTime? @map("verified_at")
  metadata         Json?
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  request      RequestInstance @relation(fields: [requestId], references: [id], onDelete: Cascade)
  evidenceFile FileAsset?      @relation(fields: [evidenceFileId], references: [id], onDelete: SetNull)

  @@index([requestId])
  @@index([voucherNumber])
  @@index([retirementStatus])
  @@map("sta_finance_payment_vouchers")
}

model Taxonomy {
  id          String   @id @default(uuid()) @db.Uuid
  key         String   @unique @db.VarChar(100)
  name        String   @db.VarChar(120)
  description String?
  module      String?  @db.VarChar(50)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  terms TaxonomyTerm[]

  @@map("sta_taxonomies")
}

model TaxonomyTerm {
  id         String   @id @default(uuid()) @db.Uuid
  taxonomyId String   @map("taxonomy_id") @db.Uuid
  value      String   @db.VarChar(120)
  label      String   @db.VarChar(120)
  sortOrder  Int      @default(0) @map("sort_order")
  isActive   Boolean  @default(true) @map("is_active")
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  taxonomy Taxonomy @relation(fields: [taxonomyId], references: [id], onDelete: Cascade)

  @@unique([taxonomyId, value], name: "unique_taxonomy_term_value")
  @@index([taxonomyId, isActive])
  @@map("sta_taxonomy_terms")
}

model Workflow {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @db.VarChar(150)
  description String?
  entityType  String   @map("entity_type") @db.VarChar(100)
  config      Json?
  isActive    Boolean  @default(true) @map("is_active")
  createdBy   BigInt?  @map("created_by")
  updatedBy   BigInt?  @map("updated_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  steps       WorkflowStep[]
  transitions WorkflowTransition[]
  instances   WorkflowInstance[]

  @@index([entityType])
  @@index([isActive])
  @@map("sta_workflows")
}

model WorkflowStep {
  id          String   @id @default(uuid()) @db.Uuid
  workflowId  String   @map("workflow_id") @db.Uuid
  name        String   @db.VarChar(150)
  description String?
  stepType    String   @default("approval") @map("step_type") @db.VarChar(50)
  order       Int      @default(0) @map("order")
  isInitial   Boolean  @default(false) @map("is_initial")
  isFinal     Boolean  @default(false) @map("is_final")
  config      Json?
  createdBy   BigInt?  @map("created_by")
  updatedBy   BigInt?  @map("updated_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  workflow    Workflow @relation(fields: [workflowId], references: [id])
  approvers   WorkflowStepApprover[]
  fromTransitions WorkflowTransition[] @relation("WorkflowFrom")
  toTransitions   WorkflowTransition[] @relation("WorkflowTo")
  instances   WorkflowInstance[] @relation("WorkflowCurrentStep")

  @@index([workflowId])
  @@index([order])
  @@map("sta_workflow_steps")
}

model WorkflowStepApprover {
  id           String   @id @default(uuid()) @db.Uuid
  stepId       String   @map("step_id") @db.Uuid
  approverType String   @map("approver_type") @db.VarChar(10)
  approverId   String   @map("approver_id") @db.VarChar(64)
  isRequired   Boolean  @default(true) @map("is_required")
  approvalOrder Int     @default(0) @map("approval_order")
  createdBy    BigInt?  @map("created_by")
  updatedBy    BigInt?  @map("updated_by")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  step WorkflowStep @relation(fields: [stepId], references: [id])

  @@index([stepId])
  @@map("sta_workflow_step_approvers")
}

model WorkflowTransition {
  id          String   @id @default(uuid()) @db.Uuid
  workflowId  String   @map("workflow_id") @db.Uuid
  fromStepId  String   @map("from_step_id") @db.Uuid
  toStepId    String   @map("to_step_id") @db.Uuid
  name        String?
  description String?
  action      String   @db.VarChar(50)
  conditions  Json?
  config      Json?
  createdBy   BigInt?  @map("created_by")
  updatedBy   BigInt?  @map("updated_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  workflow Workflow @relation(fields: [workflowId], references: [id])
  fromStep WorkflowStep @relation("WorkflowFrom", fields: [fromStepId], references: [id])
  toStep   WorkflowStep @relation("WorkflowTo", fields: [toStepId], references: [id])

  @@index([workflowId])
  @@index([fromStepId])
  @@index([toStepId])
  @@map("sta_workflow_transitions")
}

model WorkflowInstance {
  id            String   @id @default(uuid()) @db.Uuid
  workflowId    String   @map("workflow_id") @db.Uuid
  entityType    String   @map("entity_type") @db.VarChar(100)
  entityId      String   @map("entity_id") @db.VarChar(36)
  currentStepId String?  @map("current_step_id") @db.Uuid
  status        String   @default("pending") @db.VarChar(32)
  initiatedBy   BigInt?  @map("initiated_by")
  completedAt   DateTime? @map("completed_at")
  metadata      Json?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  workflow  Workflow @relation(fields: [workflowId], references: [id])
  currentStep WorkflowStep? @relation("WorkflowCurrentStep", fields: [currentStepId], references: [id])
  history   WorkflowHistory[]

  @@index([workflowId])
  @@index([status])
  @@map("sta_workflow_instances")
}

model WorkflowHistory {
  id           String   @id @default(uuid()) @db.Uuid
  instanceId   String   @map("instance_id") @db.Uuid
  transitionId String?  @map("transition_id") @db.Uuid
  fromStepId   String?  @map("from_step_id") @db.Uuid
  toStepId     String?  @map("to_step_id") @db.Uuid
  action       String   @db.VarChar(50)
  performedBy  BigInt?  @map("performed_by")
  comment      String?
  data         Json?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  instance WorkflowInstance @relation(fields: [instanceId], references: [id])

  @@index([instanceId])
  @@map("sta_workflow_history")
}

model Form {
  id              String   @id @default(uuid()) @db.Uuid
  name            String   @db.VarChar(150)
  description     String?
  module          String   @default("general") @db.VarChar(20)
  storageType     String?  @map("storage_type") @db.VarChar(20)
  targetTable     String?  @map("target_table") @db.VarChar(100)
  columnMapping   Json?    @map("column_mapping")
  isRecurring     Boolean  @default(false) @map("is_recurring")
  recurrencePattern Json?  @map("recurrence_pattern")
  workflowEnabled Boolean  @default(false) @map("workflow_enabled")
  workflowStatuses Json?   @map("workflow_statuses")
  createdByProfileId BigInt? @map("created_by_profile_id")
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  fields       FormField[]
  assignments  FormAssignment[]
  submissions  FormSubmission[]

  @@map("sta_forms")
}

model FormField {
  id            String   @id @default(uuid()) @db.Uuid
  formId        String   @map("form_id") @db.Uuid
  fieldKey      String   @map("field_key") @db.VarChar(100)
  fieldLabel    String   @map("field_label") @db.VarChar(255)
  fieldType     String   @map("field_type") @db.VarChar(20)
  fieldOptions  Json?    @map("field_options")
  isRequired    Boolean  @default(false) @map("is_required")
  validationRules Json?  @map("validation_rules")
  displayOrder  Int      @default(0) @map("display_order")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  form Form @relation(fields: [formId], references: [id])
  submissionData FormSubmissionData[]

  @@unique([formId, fieldKey], name: "unique_form_field_key")
  @@map("sta_form_fields")
}

model FormAssignment {
  id                 String   @id @default(uuid()) @db.Uuid
  formId             String   @map("form_id") @db.Uuid
  assignedToRole     String?  @map("assigned_to_role") @db.VarChar(100)
  assignedToProfileId BigInt? @map("assigned_to_profile_id")
  assignedToDepartmentId String? @map("assigned_to_department_id") @db.Uuid
  visibilityRoles    Json?    @map("visibility_roles")
  dueDate            DateTime? @map("due_date") @db.Date
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  form Form @relation(fields: [formId], references: [id])

  @@map("sta_form_assignments")
}

model FormSubmission {
  id                 String   @id @default(uuid()) @db.Uuid
  formId             String   @map("form_id") @db.Uuid
  submissionNumber   String   @map("submission_number") @db.VarChar(50)
  submittedByProfileId BigInt @map("submitted_by_profile_id")
  organizationId     String?  @map("organization_id") @db.Uuid
  status             String   @default("submitted") @db.VarChar(50)
  assignedToProfileId BigInt? @map("assigned_to_profile_id")
  resolvedAt         DateTime? @map("resolved_at")
  resolutionNotes    String?  @map("resolution_notes")
  submittedAt        DateTime @default(now()) @map("submitted_at")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  form Form @relation(fields: [formId], references: [id])
  data FormSubmissionData[]
  history FormSubmissionHistory[]
  acknowledgements Acknowledgement[]

  @@unique([submissionNumber])
  @@map("sta_form_submissions")
}

model Acknowledgement {
  id                     String    @id @default(uuid()) @db.Uuid
  userId                 BigInt    @map("user_id")
  subjectType            String    @map("subject_type") @db.VarChar(60)
  subjectId              String    @map("subject_id") @db.VarChar(191)
  subjectLabel           String?   @map("subject_label") @db.VarChar(255)
  version                String?   @db.VarChar(60)
  status                 String    @default("acknowledged") @db.VarChar(20)
  acknowledgedAt         DateTime  @default(now()) @map("acknowledged_at")
  revokedAt              DateTime? @map("revoked_at")
  sourceFormSubmissionId String?   @map("source_form_submission_id") @db.Uuid
  metadata               Json?
  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime  @updatedAt @map("updated_at")

  user             Profile         @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourceSubmission FormSubmission? @relation(fields: [sourceFormSubmissionId], references: [id], onDelete: SetNull)

  @@unique([userId, subjectType, subjectId, version], name: "unique_ack_subject_version")
  @@index([subjectType, subjectId])
  @@index([status])
  @@map("sta_acknowledgements")
}

model FormSubmissionData {
  id           BigInt   @id @default(autoincrement())
  submissionId String   @map("submission_id") @db.Uuid
  fieldId      String   @map("field_id") @db.Uuid
  fieldKey     String   @map("field_key") @db.VarChar(100)
  valueText    String?  @map("value_text") @db.VarChar(1000)
  valueNumber  Decimal? @map("value_number") @db.Decimal(15,4)
  valueDate    DateTime? @map("value_date") @db.Date
  valueDatetime DateTime? @map("value_datetime")
  valueFileUrl String?  @map("value_file_url") @db.VarChar(500)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  submission FormSubmission @relation(fields: [submissionId], references: [id])
  field      FormField @relation(fields: [fieldId], references: [id])

  @@unique([submissionId, fieldId], name: "unique_submission_field")
  @@map("sta_form_submission_data")
}

model FormSubmissionHistory {
  id           String   @id @default(uuid()) @db.Uuid
  submissionId String   @map("submission_id") @db.Uuid
  actionType   String   @map("action_type") @db.VarChar(20)
  performedByProfileId BigInt? @map("performed_by_profile_id")
  oldValue     String?  @map("old_value")
  newValue     String?  @map("new_value")
  notes        String?
  createdAt    DateTime @default(now()) @map("created_at")

  submission FormSubmission @relation(fields: [submissionId], references: [id])

  @@map("sta_form_submission_history")
}
