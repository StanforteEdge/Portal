datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum TokenType {
  access
  refresh
  reset
  invite
}

enum OrganizationType {
  group
  venture
  shared_function
}

enum GroupUserRole {
  member
  admin
  moderator
}

enum RequestStatus {
  draft
  returned
  sent
  approval
  cleared
  approved
  rejected
  cancelled
  payment_processing
  disbursed
  confirmed
  partially_disbursed
  pending_retirement
  retired
  completed
}

enum EmploymentType {
  full_time
  contract
  intern
  consultant
}

enum EmploymentStatus {
  draft
  active
  suspended
  exited
}

enum WorkMode {
  onsite
  hybrid
  remote
}

enum OnboardingStatus {
  invited
  accepted
  profile_pending
  forms_pending
  hr_review
  completed
}

enum WorkItemType {
  weekly_task
  daily_task
  project_activity
  recurring_responsibility
  ad_hoc
}

enum WorkItemStatus {
  planned
  in_progress
  completed
  blocked
  carried_over
  cancelled
}

enum WorkPriority {
  low
  medium
  high
  critical
}

enum WorkLogApprovalStatus {
  draft
  submitted
  approved
  rejected
}

model Profile {
  id                    BigInt    @id @default(autoincrement())
  wpUserId              BigInt?   @map("wp_user_id")
  username              String?   @unique @db.VarChar(100)
  email                 String    @unique @db.VarChar(255)
  passwordHash          String?   @map("password_hash") @db.VarChar(255)
  type                  String    @db.VarChar(50)
  status                String    @default("active") @db.VarChar(20)
  firstName             String?   @map("first_name") @db.VarChar(100)
  lastName              String?   @map("last_name") @db.VarChar(100)
  dateOfBirth           DateTime? @map("date_of_birth") @db.Date
  gender                String?   @db.VarChar(10)
  phone                 String?   @db.VarChar(30)
  address               String?   @db.VarChar(255)
  nationality           String?   @db.VarChar(100)
  state                 String?   @db.VarChar(100)
  lga                   String?   @db.VarChar(100)
  maritalStatus         String?   @map("marital_status") @db.VarChar(30)
  avatar                String?   @db.VarChar(255)
  bio                   String?
  occupation            String?   @db.VarChar(100)
  employmentType        String?   @map("employment_type") @db.VarChar(20)
  primaryOrganizationId BigInt?   @map("primary_organization_id")
  signatureFileId       String?   @map("signature_file_id") @db.Uuid
  lastLogin             DateTime? @map("last_login") @db.Timestamp(6)
  failedLoginAttempts   Int       @default(0) @map("failed_login_attempts")
  lockoutUntil          DateTime? @map("lockout_until")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  primaryOrganization Organization? @relation("PrimaryOrganization", fields: [primaryOrganizationId], references: [id])
  signatureFile       FileAsset?    @relation("ProfileSignatureFile", fields: [signatureFileId], references: [id])

  organizations                   ProfileOrganization[]
  roles                           UserRole[]
  tokens                          Token[]
  groups                          GroupUser[]
  requests                        RequestInstance[]                 @relation("RequestCreatedBy")
  uploadedFiles                   FileAsset[]                       @relation("FileUploadedBy")
  emailLogs                       EmailLog[]                        @relation("EmailLogUser")
  employeeProfile                 EmployeeProfile?
  managedEmployees                EmployeeProfile[]                 @relation("EmployeeManager")
  onboardingProgress              OnboardingProgress?
  employeeMeta                    EmployeeMeta[]
  attendanceEntries               AttendanceEntry[]
  attendanceDaily                 AttendanceDaily[]
  attendanceSubjectCorrections    AttendanceCorrection[]            @relation("AttendanceCorrectionUser")
  attendanceCorrections           AttendanceCorrection[]            @relation("AttendanceCorrectionRequestedBy")
  attendanceCorrectionReviews     AttendanceCorrection[]            @relation("AttendanceCorrectionReviewedBy")
  attendanceSubjectExceptions     AttendanceException[]             @relation("AttendanceExceptionUser")
  attendanceExceptions            AttendanceException[]             @relation("AttendanceExceptionCreatedBy")
  attendanceExceptionReviews      AttendanceException[]             @relation("AttendanceExceptionReviewedBy")
  leaveBalanceLedger              LeaveBalanceLedger[]
  acknowledgements                Acknowledgement[]
  documentAcknowledgements        DocumentAcknowledgement[]
  assignedFinanceAssets           FinanceAsset[]                    @relation("FinanceAssetAssignedTo")
  verifiedFinanceAssets           FinanceAsset[]                    @relation("FinanceAssetVerifiedBy")
  createdFinanceAssets            FinanceAsset[]                    @relation("FinanceAssetCreatedBy")
  updatedFinanceAssets            FinanceAsset[]                    @relation("FinanceAssetUpdatedBy")
  assetVerificationsPerformed     FinanceAssetVerification[]        @relation("FinanceAssetVerificationPerformedBy")
  assetVerificationAssignees      FinanceAssetVerification[]        @relation("FinanceAssetVerificationAssignedTo")
  assetDisposalsApproved          FinanceAssetDisposal[]            @relation("FinanceAssetDisposalApprovedBy")
  assetDisposalsCreated           FinanceAssetDisposal[]            @relation("FinanceAssetDisposalCreatedBy")
  createdFinanceChartAccounts     FinanceChartAccount[]             @relation("FinanceChartAccountCreatedBy")
  createdFinanceReportingPeriods  FinanceReportingPeriod[]          @relation("FinanceReportingPeriodCreatedBy")
  postedFinanceJournalEntries     FinanceJournalEntry[]             @relation("FinanceJournalEntryPostedBy")
  createdFinanceContacts          FinanceContact[]                  @relation("FinanceContactCreatedBy")
  updatedFinanceContacts          FinanceContact[]                  @relation("FinanceContactUpdatedBy")
  createdFinanceSalesInvoices     FinanceSalesInvoice[]             @relation("FinanceSalesInvoiceCreatedBy")
  updatedFinanceSalesInvoices     FinanceSalesInvoice[]             @relation("FinanceSalesInvoiceUpdatedBy")
  createdFinanceBills             FinanceBillHeader[]               @relation("FinanceBillCreatedBy")
  updatedFinanceBills             FinanceBillHeader[]               @relation("FinanceBillUpdatedBy")
  createdFinanceReceipts          FinanceReceipt[]                  @relation("FinanceReceiptCreatedBy")
  createdFinanceVendorPayments    FinanceVendorPayment[]            @relation("FinanceVendorPaymentCreatedBy")
  createdFinanceReportNotes       FinanceReportNote[]               @relation("FinanceReportNoteCreatedBy")
  updatedFinanceReportNotes       FinanceReportNote[]               @relation("FinanceReportNoteUpdatedBy")
  proposedVoucherCorrections      FinancePaymentVoucherCorrection[] @relation("FinancePaymentVoucherCorrectionProposedBy")
  reviewedVoucherCorrections      FinancePaymentVoucherCorrection[] @relation("FinancePaymentVoucherCorrectionReviewedBy")
  payrollWorkers                  PayrollWorker[]                   @relation("PayrollWorkerProfile")
  payrollRunsPrepared             PayrollRun[]                      @relation("PayrollRunPreparedBy")
  payrollRunsReviewed             PayrollRun[]                      @relation("PayrollRunReviewedBy")
  payrollRunsApproved             PayrollRun[]                      @relation("PayrollRunApprovedBy")
  payrollRunsAuthorized           PayrollRun[]                      @relation("PayrollRunAuthorizedBy")
  payrollRunEvents                PayrollRunEvent[]                 @relation("PayrollRunEventActor")
  payrollPayslipDistributionsSent PayrollPayslipDistribution[]      @relation("PayrollPayslipDistributionSentBy")
  payrollNotificationPreference   PayrollNotificationPreference?
  payrollImportJobsUploaded       PayrollImportJob[]                @relation("PayrollImportJobUploadedBy")
  payrollImportJobsRetried        PayrollImportJob[]                @relation("PayrollImportJobRetriedBy")
  payrollSettingsUpdated          PayrollSetting[]                  @relation("PayrollSettingUpdatedBy")
  projectTimesheetsApproved       ProjectTimesheetEntry[]           @relation("ProjectTimesheetApprovedBy")
  projectTimesheetsCreated        ProjectTimesheetEntry[]           @relation("ProjectTimesheetCreatedBy")
  createdWorkItems                WorkItem[]                        @relation("WorkItemCreatedBy")
  assignedWorkItems               WorkItem[]                        @relation("WorkItemAssignedTo")
  plannedWorkItems                WorkItem[]                        @relation("WorkItemAssignedBy")
  workLogs                        WorkLog[]                         @relation("WorkLogStaff")
  approvedWorkLogs                WorkLog[]                         @relation("WorkLogApprovedBy")
  ownedTeamGoals                  TeamGoal[]                        @relation("TeamGoalOwner")
  createdTeamGoals                TeamGoal[]                        @relation("TeamGoalCreatedBy")
  ownedTeamObjectives             TeamObjective[]                   @relation("TeamObjectiveOwner")
  createdTeamObjectives           TeamObjective[]                   @relation("TeamObjectiveCreatedBy")
  ownedTeamKpis                   TeamKpi[]                         @relation("TeamKpiOwner")
  createdTeamKpis                 TeamKpi[]                         @relation("TeamKpiCreatedBy")
  createdFinanceItems             FinanceItem[]                     @relation("FinanceItemCreatedBy")
  updatedFinanceItems             FinanceItem[]                     @relation("FinanceItemUpdatedBy")
  createdFinanceExpenses          FinanceExpense[]                  @relation("FinanceExpenseCreatedBy")
  updatedFinanceExpenses          FinanceExpense[]                  @relation("FinanceExpenseUpdatedBy")
  createdDeductionTypes           FinanceDeductionType[]            @relation("DeductionTypeCreatedBy")
  updatedDeductionTypes           FinanceDeductionType[]            @relation("DeductionTypeUpdatedBy")
  createdPVDeductions             FinancePVDeduction[]              @relation("PVDeductionCreatedBy")
  createdWHTRemittances           FinanceWHTRemittance[]            @relation("WHTRemittanceCreatedBy")
  updatedWHTRemittances           FinanceWHTRemittance[]            @relation("WHTRemittanceUpdatedBy")
  createdRequestDeductions        FinanceRequestDeduction[]         @relation("RequestDeductionCreatedBy")

  @@map("sta_profiles")
}

model EmployeeProfile {
  id               String           @id @default(uuid()) @db.Uuid
  userId           BigInt           @unique @map("user_id")
  employeeCode     String?          @unique @map("employee_code") @db.VarChar(60)
  jobTitle         String?          @map("job_title") @db.VarChar(120)
  jobDescription   String?          @map("job_description")
  managerUserId    BigInt?          @map("manager_user_id")
  employmentType   EmploymentType?  @map("employment_type")
  employmentStatus EmploymentStatus @default(draft) @map("employment_status")
  hireDate         DateTime?        @map("hire_date") @db.Date
  confirmationDate DateTime?        @map("confirmation_date") @db.Date
  exitDate         DateTime?        @map("exit_date") @db.Date
  workMode         WorkMode?        @map("work_mode")
  createdBy        BigInt?          @map("created_by")
  updatedBy        BigInt?          @map("updated_by")
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  user    Profile  @relation(fields: [userId], references: [id], onDelete: Cascade)
  manager Profile? @relation("EmployeeManager", fields: [managerUserId], references: [id], onDelete: SetNull)

  @@index([managerUserId])
  @@index([employmentStatus])
  @@map("sta_employee_profiles")
}

model EmployeeMeta {
  id        String   @id @default(uuid()) @db.Uuid
  userId    BigInt   @map("user_id")
  metaKey   String   @map("meta_key") @db.VarChar(120)
  metaValue Json?    @map("meta_value")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user Profile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, metaKey], name: "employee_meta_unique")
  @@index([metaKey])
  @@map("sta_employee_meta")
}

model AttendanceEntry {
  id               String   @id @default(uuid()) @db.Uuid
  userId           BigInt   @map("user_id")
  entryType        String   @map("entry_type") @db.VarChar(30)
  entryAt          DateTime @map("entry_at")
  workDate         DateTime @map("work_date") @db.Date
  attendanceMode   String?  @map("attendance_mode") @db.VarChar(30)
  officeLocationId BigInt?  @map("office_location_id")
  latitude         Decimal? @db.Decimal(10, 7)
  longitude        Decimal? @db.Decimal(10, 7)
  geofenceStatus   String?  @map("geofence_status") @db.VarChar(30)
  source           String   @default("web") @db.VarChar(30)
  metadata         Json?
  createdBy        BigInt?  @map("created_by")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  user           Profile                @relation(fields: [userId], references: [id], onDelete: Cascade)
  officeLocation OfficeLocation?        @relation(fields: [officeLocationId], references: [id], onDelete: SetNull)
  corrections    AttendanceCorrection[]
  exceptions     AttendanceException[]

  @@index([userId, workDate])
  @@index([entryType, entryAt])
  @@map("sta_attendance_entries")
}

model AttendanceDaily {
  id                   String    @id @default(uuid()) @db.Uuid
  userId               BigInt    @map("user_id")
  workDate             DateTime  @map("work_date") @db.Date
  status               String    @default("absent") @db.VarChar(20)
  attendanceMode       String?   @map("attendance_mode") @db.VarChar(30)
  expectedMode         String?   @map("expected_mode") @db.VarChar(30)
  reconciliationStatus String?   @map("reconciliation_status") @db.VarChar(30)
  officeLocationId     BigInt?   @map("office_location_id")
  geofenceStatus       String?   @map("geofence_status") @db.VarChar(30)
  scheduledMinutes     Int       @default(0) @map("scheduled_minutes")
  workedMinutes        Int       @default(0) @map("worked_minutes")
  lateMinutes          Int       @default(0) @map("late_minutes")
  overtimeMinutes      Int       @default(0) @map("overtime_minutes")
  firstInAt            DateTime? @map("first_in_at")
  lastOutAt            DateTime? @map("last_out_at")
  policySnapshot       Json?     @map("policy_snapshot")
  computedAt           DateTime  @default(now()) @map("computed_at")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  user           Profile                @relation(fields: [userId], references: [id], onDelete: Cascade)
  officeLocation OfficeLocation?        @relation(fields: [officeLocationId], references: [id], onDelete: SetNull)
  corrections    AttendanceCorrection[]
  exceptions     AttendanceException[]

  @@unique([userId, workDate], name: "unique_attendance_daily")
  @@index([status])
  @@map("sta_attendance_daily")
}

model OfficeLocation {
  id           BigInt   @id @default(autoincrement())
  name         String   @db.VarChar(255)
  address      String?  @db.VarChar(255)
  latitude     Decimal  @db.Decimal(10, 7)
  longitude    Decimal  @db.Decimal(10, 7)
  radiusMeters Int      @default(150) @map("radius_meters")
  isActive     Boolean  @default(true) @map("is_active")
  metadata     Json?
  createdBy    BigInt?  @map("created_by")
  updatedBy    BigInt?  @map("updated_by")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  organizations                 OrganizationOfficeLocation[]
  attendanceEntries             AttendanceEntry[]
  attendanceDaily               AttendanceDaily[]
  attendanceCorrections         AttendanceCorrection[]
  proposedAttendanceCorrections AttendanceCorrection[]       @relation("AttendanceCorrectionProposedOfficeLocation")
  attendanceExceptions          AttendanceException[]
  attendanceHolidays            AttendanceHoliday[]

  @@map("sta_office_locations")
}

model OrganizationOfficeLocation {
  id               BigInt   @id @default(autoincrement())
  organizationId   BigInt   @map("organization_id")
  officeLocationId BigInt   @map("office_location_id")
  isPrimary        Boolean  @default(false) @map("is_primary")
  createdAt        DateTime @default(now()) @map("created_at")

  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  officeLocation OfficeLocation @relation(fields: [officeLocationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, officeLocationId], name: "unique_org_office_location")
  @@index([officeLocationId])
  @@map("sta_organization_office_locations")
}

model AttendanceHoliday {
  id               String   @id @default(uuid()) @db.Uuid
  organizationId   BigInt?  @map("organization_id")
  officeLocationId BigInt?  @map("office_location_id")
  holidayDate      DateTime @map("holiday_date") @db.Date
  name             String   @db.VarChar(255)
  isRecurring      Boolean  @default(false) @map("is_recurring")
  isActive         Boolean  @default(true) @map("is_active")
  createdBy        BigInt?  @map("created_by")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  organization   Organization?   @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  officeLocation OfficeLocation? @relation(fields: [officeLocationId], references: [id], onDelete: SetNull)

  @@index([organizationId, holidayDate])
  @@index([officeLocationId, holidayDate])
  @@map("sta_attendance_holidays")
}

model AttendanceCorrection {
  id                       String    @id @default(uuid()) @db.Uuid
  userId                   BigInt    @map("user_id")
  attendanceDailyId        String?   @map("attendance_daily_id") @db.Uuid
  attendanceEntryId        String?   @map("attendance_entry_id") @db.Uuid
  officeLocationId         BigInt?   @map("office_location_id")
  requestType              String    @map("request_type") @db.VarChar(40)
  status                   String    @default("pending") @db.VarChar(20)
  requestedAt              DateTime  @default(now()) @map("requested_at")
  requestedBy              BigInt    @map("requested_by")
  reviewedAt               DateTime? @map("reviewed_at")
  reviewedBy               BigInt?   @map("reviewed_by")
  reason                   String
  workDate                 DateTime  @map("work_date") @db.Date
  proposedAt               DateTime? @map("proposed_at")
  proposedMode             String?   @map("proposed_mode") @db.VarChar(30)
  proposedOfficeLocationId BigInt?   @map("proposed_office_location_id")
  proposedLatitude         Decimal?  @map("proposed_latitude") @db.Decimal(10, 7)
  proposedLongitude        Decimal?  @map("proposed_longitude") @db.Decimal(10, 7)
  reviewNotes              String?   @map("review_notes")
  snapshotJson             Json?     @map("snapshot_json")
  metadata                 Json?
  createdAt                DateTime  @default(now()) @map("created_at")
  updatedAt                DateTime  @updatedAt @map("updated_at")

  user                   Profile          @relation("AttendanceCorrectionUser", fields: [userId], references: [id], onDelete: Cascade)
  requester              Profile          @relation("AttendanceCorrectionRequestedBy", fields: [requestedBy], references: [id], onDelete: Cascade)
  reviewer               Profile?         @relation("AttendanceCorrectionReviewedBy", fields: [reviewedBy], references: [id], onDelete: SetNull)
  attendanceDaily        AttendanceDaily? @relation(fields: [attendanceDailyId], references: [id], onDelete: SetNull)
  attendanceEntry        AttendanceEntry? @relation(fields: [attendanceEntryId], references: [id], onDelete: SetNull)
  officeLocation         OfficeLocation?  @relation(fields: [officeLocationId], references: [id], onDelete: SetNull)
  proposedOfficeLocation OfficeLocation?  @relation("AttendanceCorrectionProposedOfficeLocation", fields: [proposedOfficeLocationId], references: [id], onDelete: SetNull)

  @@index([userId, workDate])
  @@index([status, requestedAt])
  @@map("sta_attendance_corrections")
}

model AttendanceException {
  id                String    @id @default(uuid()) @db.Uuid
  userId            BigInt    @map("user_id")
  attendanceDailyId String?   @map("attendance_daily_id") @db.Uuid
  attendanceEntryId String?   @map("attendance_entry_id") @db.Uuid
  officeLocationId  BigInt?   @map("office_location_id")
  exceptionType     String    @map("exception_type") @db.VarChar(40)
  status            String    @default("active") @db.VarChar(20)
  workDate          DateTime  @map("work_date") @db.Date
  attendanceMode    String?   @map("attendance_mode") @db.VarChar(30)
  reason            String
  notes             String?
  createdBy         BigInt    @map("created_by")
  reviewedBy        BigInt?   @map("reviewed_by")
  reviewedAt        DateTime? @map("reviewed_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  user            Profile          @relation("AttendanceExceptionUser", fields: [userId], references: [id], onDelete: Cascade)
  creator         Profile          @relation("AttendanceExceptionCreatedBy", fields: [createdBy], references: [id], onDelete: Cascade)
  reviewer        Profile?         @relation("AttendanceExceptionReviewedBy", fields: [reviewedBy], references: [id], onDelete: SetNull)
  attendanceDaily AttendanceDaily? @relation(fields: [attendanceDailyId], references: [id], onDelete: SetNull)
  attendanceEntry AttendanceEntry? @relation(fields: [attendanceEntryId], references: [id], onDelete: SetNull)
  officeLocation  OfficeLocation?  @relation(fields: [officeLocationId], references: [id], onDelete: SetNull)

  @@index([userId, workDate])
  @@index([status, exceptionType])
  @@map("sta_attendance_exceptions")
}

model LeaveBalanceLedger {
  id              String   @id @default(uuid()) @db.Uuid
  userId          BigInt   @map("user_id")
  leaveTypeKey    String   @map("leave_type_key") @db.VarChar(100)
  periodYear      Int      @map("period_year")
  deltaDays       Decimal  @map("delta_days") @db.Decimal(7, 2)
  entryType       String   @map("entry_type") @db.VarChar(30)
  sourceRequestId BigInt?  @map("source_request_id")
  notes           String?
  metadata        Json?
  createdBy       BigInt?  @map("created_by")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user          Profile          @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourceRequest RequestInstance? @relation(fields: [sourceRequestId], references: [id], onDelete: SetNull)

  @@index([userId, leaveTypeKey, periodYear])
  @@index([entryType])
  @@index([sourceRequestId])
  @@map("sta_leave_balance_ledger")
}

model OnboardingProgress {
  id          String           @id @default(uuid()) @db.Uuid
  userId      BigInt           @unique @map("user_id")
  status      OnboardingStatus @default(invited)
  currentStep String?          @map("current_step") @db.VarChar(80)
  stepsJson   Json?            @map("steps_json")
  dueDate     DateTime?        @map("due_date") @db.Date
  completedAt DateTime?        @map("completed_at")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  user Profile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
  @@map("sta_onboarding_progress")
}

model Organization {
  id                   BigInt           @id @default(autoincrement())
  name                 String           @db.VarChar(255)
  code                 String           @unique @db.VarChar(50)
  parentOrganizationId BigInt?          @map("parent_organization_id")
  organizationType     OrganizationType @default(venture) @map("organization_type")
  isActive             Boolean          @default(true) @map("is_active")
  metadata             Json?
  createdAt            DateTime         @map("created_at")
  updatedAt            DateTime         @map("updated_at")

  parentOrganization Organization?  @relation("OrgParent", fields: [parentOrganizationId], references: [id])
  childOrganizations Organization[] @relation("OrgParent")
  primaryProfiles    Profile[]      @relation("PrimaryOrganization")

  profiles                       ProfileOrganization[]
  userRoles                      UserRole[]
  groups                         Group[]
  groupMappings                  GroupOrganization[]             @relation("GroupOrganizationOrganization")
  groupMemberScopes              GroupUserOrganizationScope[]
  officeLocations                OrganizationOfficeLocation[]
  attendanceHolidays             AttendanceHoliday[]
  requests                       RequestInstance[]
  requestGroups                  RequestGroup[]
  fileAssets                     FileAsset[]
  financeAccounts                FinanceAccount[]
  financeAssets                  FinanceAsset[]
  financeChartAccounts           FinanceChartAccount[]
  financeJournalLines            FinanceJournalLine[]
  financeContacts                FinanceContact[]
  financeSalesInvoices           FinanceSalesInvoice[]
  financeBillHeaders             FinanceBillHeader[]
  documents                      Document[]
  payrollWorkers                 PayrollWorker[]
  payrollWorkerAllocations       PayrollWorkerAllocation[]
  payrollRunItems                PayrollRunItem[]
  payrollRunItemAllocations      PayrollRunItemAllocation[]
  payrollRunTimesheetAllocations PayrollRunTimesheetAllocation[]
  projectTimesheetEntries        ProjectTimesheetEntry[]
  payrollSettings                PayrollSetting[]
  payrollRuns                    PayrollRun[]
  workItems                      WorkItem[]
  workLogs                       WorkLog[]
  teamGoals                      TeamGoal[]
  teamObjectives                 TeamObjective[]
  teamKpis                       TeamKpi[]

  @@map("sta_organizations")
}

model ProfileOrganization {
  id             String    @id @default(uuid()) @db.Uuid
  profileId      BigInt    @map("profile_id")
  organizationId BigInt    @map("organization_id")
  isPrimary      Boolean   @default(false) @map("is_primary")
  startDate      DateTime? @map("start_date") @db.Date
  endDate        DateTime? @map("end_date") @db.Date
  createdAt      DateTime  @map("created_at")

  profile      Profile      @relation(fields: [profileId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([profileId, organizationId], name: "profile_org_unique")
  @@map("sta_profile_organizations")
}

model Role {
  id          BigInt   @id @default(autoincrement())
  name        String   @db.VarChar(50)
  description String?
  slug        String   @unique @db.VarChar(50)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @map("created_at")
  updatedAt   DateTime @map("updated_at")

  permissions RolePermission[]
  users       UserRole[]

  @@map("sta_roles")
}

model Permission {
  id          BigInt   @id @default(autoincrement())
  name        String   @db.VarChar(50)
  description String?
  slug        String   @unique @db.VarChar(50)
  module      String?  @db.VarChar(50)
  createdAt   DateTime @map("created_at")
  updatedAt   DateTime @map("updated_at")

  roles RolePermission[]

  @@map("sta_permissions")
}

