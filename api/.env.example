# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/stanforte?schema=public

# Server
PORT=3000

# JWT
JWT_SECRET=change-me
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-too
JWT_REFRESH_EXPIRES_IN=30d

# CORS — comma-separated origins allowed to access the API
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Rate limiting
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_LOGIN_RATE_LIMIT_MAX=10        # Max login attempts per window
AUTH_FORGOT_RATE_LIMIT_MAX=5        # Max forgot-password requests per window
AUTH_INVITE_ACCEPT_RATE_LIMIT_MAX=10

# App URLs
APP_BASE_URL=http://localhost:3000
APP_URL=http://localhost:3000

# File serving
FILE_BASE_URL=http://localhost:3000

# Email / SMTP
EMAIL_NOTIFICATIONS_ENABLED=true
MAIL_FROM=no-reply@stanforteedge.com
MAIL_SUPPORT_EMAIL=support@stanforteedge.com
MAIL_LOGO_URL=
MAIL_MESSAGE_ID_DOMAIN=stanforteedge.com
SMTP_HOST=localhost
SMTP_PORT=1025                          # 1025 = Mailpit/Mailhog, 587 = real SMTP
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false

# PDF generation — path to Chrome executable (required by puppeteer)
PDF_BROWSER_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome
PDF_LOGO_PATH=public/branding/logo.png

# File upload limits
FILE_UPLOAD_MAX_MB=10
FILE_UPLOAD_ALLOWED_MIME=application/pdf,image/jpeg,image/png,image/webp,text/plain,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document
