{
  "name": "portal-api",
  "version": "0.1.0",
  "private": true,
  "description": "StanforteEdge Portal API (NestJS + Postgres)",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "prepare:runtime": "prisma migrate deploy && prisma generate",
    "deploy:server": "npm run prepare:runtime && npm run build",
    "seed:rbac": "node scripts/seed-rbac.js",
    "seed:first-user": "node scripts/seed-first-user.js",
    "seed:finance-requests": "node scripts/seed-finance-requests.js",
    "seed:documents": "node scripts/seed-documents.js",
    "seed:hr-onboarding-forms": "node scripts/seed-hr-onboarding.js",
    "seed:hr-leave-system": "node scripts/seed-hr-leave-system.js",
    "seed:release-baseline": "node scripts/seed-release-baseline.js",
    "seed:grant-all-roles": "node scripts/grant-all-roles.js",
    "repair:request-workflows": "node scripts/repair-request-workflow-links.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy"
  },
  "dependencies": {
    "@nestjs/common": "^10.3.0",
    "@nestjs/core": "^10.3.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.2",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/swagger": "^7.4.2",
    "@prisma/client": "^5.12.0",
    "@types/nodemailer": "^7.0.10",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^17.3.1",
    "express-rate-limit": "^8.2.1",
    "jszip": "^3.10.1",
    "nodemailer": "^8.0.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pdf-lib": "^1.17.1",
    "puppeteer-core": "^24.37.4",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/multer": "^2.0.0",
    "@types/node": "^20.11.30",
    "@types/passport-jwt": "^4.0.1",
    "prisma": "^5.12.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.3"
  }
}
